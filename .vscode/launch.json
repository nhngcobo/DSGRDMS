{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Launch .NET Server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/DSGRDMS.Server/bin/Debug/net10.0/DSGRDMS.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/DSGRDMS.Server",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "Launch React Client",
            "type": "msedge",
            "request": "launch",
            "url": "https://localhost:54480",
            "webRoot": "${workspaceFolder}/dsgrdms.client",
            "preLaunchTask": "npm: dev - dsgrdms.client"
        }
    ],
    "compounds": [
        {
            "name": "Launch Server & Client",
            "configurations": ["Launch .NET Server", "Launch React Client"]
        }
    ]
}
